# Database
MONGODB_URI=#

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Admin seed credentials
# Change these, then run: npm run seed:admin
ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-at-least-12-characters

# Development default: public/uploads
# VPS example: /var/www/gts-katha-media
MEDIA_STORAGE_ROOT=public/uploads

# Served by Next.js locally or Nginx in production.
NEXT_PUBLIC_MEDIA_BASE_URL=/uploads

# Gmail SMTP password-reset emails
# Use a Google App Password, never your normal Gmail password.
GMAIL_SMTP_USER=your-account@gmail.com
GMAIL_SMTP_APP_PASSWORD=replace-with-google-app-password
EMAIL_FROM=your-account@gmail.com
